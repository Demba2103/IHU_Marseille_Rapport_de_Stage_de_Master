

#!/bin/bash

INPUT_DIR="/home/demba_ba/WGS/files/trimmed_reads"
OUTPUT_DIR="/home/demba_ba/WGS/files/spades_assemblies"
THREADS=8

mkdir -p $OUTPUT_DIR

samples=(
SRR10058833
SRR10058838
SRR10058842
)

for s in "${samples[@]}"
do
    echo "Assemblage SPAdes pour $s ..."

    spades.py \
    -1 ${INPUT_DIR}/${s}_R1_paired.fastq.gz \
    -2 ${INPUT_DIR}/${s}_R2_paired.fastq.gz \
    -o ${OUTPUT_DIR}/${s} \
    -t $THREADS \
    -m 32

done

echo "Assemblage terminé ✔"
