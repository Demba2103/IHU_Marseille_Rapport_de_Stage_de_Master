

#!/bin/bash

CONTIGS_DIR="/home/demba_ba/WGS/files/spades_assemblies"
OUTPUT_DIR="/home/demba_ba/WGS/files/prokka_result"

mkdir -p $OUTPUT_DIR

samples=(
SRR10058833
SRR10058838
SRR10058842
)

for s in "${samples[@]}"
do
    echo "Annotation Prokka pour $s ..."

    prokka ${CONTIGS_DIR}/${s}/contigs.fasta \
    --outdir ${OUTPUT_DIR}/${s} \
    --prefix ${s} \
    --cpus 8

done

echo "Annotation terminée ✔"
